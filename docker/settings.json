{
  "theme": "auto",
  "dangerouslySkipPermissions": true,
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "IS_SANDBOX": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(export ANTHROPIC_API_KEY=*)"
    ]
  },
  "enabledPlugins": {
    "datum-gtm@datum-claude-code-plugins": true,
    "datum-platform@datum-claude-code-plugins": true,
    "milo-activity@datum-claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "datum-claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "datum-cloud/claude-code-plugins"
      }
    }
  }
}
