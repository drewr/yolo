#!/usr/bin/env bash
# Run an agent in the sandboxed Docker/Podman environment.
#
# Usage:
#   yolo [DOCKER_FLAGS] -- [CLAUDE_ARGS...]
#
# Mount additional directories with -v flags before --:
#   yolo -v /path/to/other:/workspace/other -- -p "do the thing"
#
# ANTHROPIC_API_KEY, SSH_AUTH_SOCK, and GIT_SIGNING_KEY are passed through from the environment.
# CLAUDE_SESSIONS defaults to the OS-appropriate data dir; override to store sessions elsewhere.
# CONTAINER_RUNTIME can be set to "docker" or "podman" to override auto-detection.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="yolo:local"

if [ -z "${CONTAINER_RUNTIME:-}" ]; then
  if command -v docker &>/dev/null; then
    CONTAINER_RUNTIME=docker
  elif command -v podman &>/dev/null; then
    CONTAINER_RUNTIME=podman
  else
    echo "error: neither docker nor podman found in PATH" >&2
    exit 1
  fi
fi

"$CONTAINER_RUNTIME" build --progress=plain -t "$IMAGE" "$SCRIPT_DIR/docker"

# Split args at -- into docker flags and container command
docker_flags=()
cmd=()
found_sep=false
for arg in "$@"; do
  if [[ "$arg" == "--" ]]; then
    found_sep=true
  elif $found_sep; then
    cmd+=("$arg")
  else
    docker_flags+=("$arg")
  fi
done

if [ -z "${GITHUB_TOKEN:-}" ]; then
  echo "error: GITHUB_TOKEN is not set" >&2
  exit 1
fi

ssh_flags=()
if [ -n "${SSH_AUTH_SOCK:-}" ]; then
  ssh_flags+=(-v "$SSH_AUTH_SOCK:/ssh-agent" -e SSH_AUTH_SOCK=/ssh-agent)
fi

if [ -f "${HOME}/.ssh/allowed_signers" ]; then
  ssh_flags+=(-v "${HOME}/.ssh/allowed_signers:/root/.ssh/allowed_signers:ro")
fi

if [ -z "${CLAUDE_SESSIONS:-}" ]; then
  case "${OSTYPE:-}" in
    darwin*)  CLAUDE_SESSIONS="$HOME/Library/Application Support/yolo/sessions" ;;
    msys*|cygwin*|win32*) CLAUDE_SESSIONS="${APPDATA:-$HOME/AppData/Roaming}/yolo/sessions" ;;
    *)        CLAUDE_SESSIONS="${XDG_DATA_HOME:-$HOME/.local/share}/yolo/sessions" ;;
  esac
fi
mkdir -p "$CLAUDE_SESSIONS"
sessions_flags=(-v "$CLAUDE_SESSIONS:/root/.claude/projects")

"$CONTAINER_RUNTIME" run --rm -it \
  -e ANTHROPIC_API_KEY \
  -e GITHUB_TOKEN \
  -e GIT_EMAIL="${GIT_EMAIL:-}" \
  -e GIT_NAME="${GIT_NAME:-}" \
  -e GIT_SIGNING_KEY="${GIT_SIGNING_KEY:-}" \
  -e HOST_UID="$(id -u)" \
  -e HOST_GID="$(id -g)" \
  "${ssh_flags[@]}" \
  "${sessions_flags[@]}" \
  -w /workspace \
  "${docker_flags[@]}" \
  "$IMAGE" \
  "${cmd[@]}"
