#!/usr/bin/env bash
# Run an agent in the sandboxed Docker environment.
#
# Usage:
#   docker/run [DOCKER_FLAGS] -- [CLAUDE_ARGS...]
#
# Mount additional directories with -v flags before --:
#   docker/run -v /path/to/other:/workspace/other -- -p "do the thing"
#
# ANTHROPIC_API_KEY, SSH_AUTH_SOCK, and GIT_SIGNING_KEY are passed through from the environment.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="agent-runtime:local"

docker build --progress=plain -t "$IMAGE" "$SCRIPT_DIR/docker"

# Split args at -- into docker flags and container command
docker_flags=()
cmd=()
found_sep=false
for arg in "$@"; do
  if [[ "$arg" == "--" ]]; then
    found_sep=true
  elif $found_sep; then
    cmd+=("$arg")
  else
    docker_flags+=("$arg")
  fi
done

ssh_flags=()
if [ -n "${SSH_AUTH_SOCK:-}" ]; then
  ssh_flags+=(-v "$SSH_AUTH_SOCK:/ssh-agent" -e SSH_AUTH_SOCK=/ssh-agent)
fi

docker run --rm -it \
  -e ANTHROPIC_API_KEY \
  -e GIT_EMAIL="${GIT_EMAIL:-}" \
  -e GIT_NAME="${GIT_NAME:-}" \
  -e GIT_SIGNING_KEY="${GIT_SIGNING_KEY:-}" \
  "${ssh_flags[@]}" \
  -w /workspace \
  "${docker_flags[@]}" \
  "$IMAGE" \
  "${cmd[@]}"
